	/// Schutzbriefe und AppleCare Produkte
	measure Schutzbriefe = CALCULATE( SUM('FACT_Umsatz Produkt'[Menge]), FILTER( DIM_Produkt, DIM_Produkt[IstSchutzbrief] = TRUE()))
