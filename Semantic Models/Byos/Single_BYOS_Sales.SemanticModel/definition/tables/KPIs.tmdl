		formatStringDefinition = bpi.Formating.Qty()

	measure 'Forecast Qty' = ```
			
			/*
			    Für die Berechung nehmen wir die letzten 4 Jahre 
			*/
			VAR sum4Years = CALCULATE([Actuals Qty], DATEADD('DIM_Datum Umsatz'[Datum],-4, YEAR)) 
			VAR sum3Years = CALCULATE([Actuals Qty], DATEADD('DIM_Datum Umsatz'[Datum],-3, YEAR)) 
			VAR sum2Years = CALCULATE([Actuals Qty], DATEADD('DIM_Datum Umsatz'[Datum],-2, YEAR)) 
			VAR sum1Years = CALCULATE([Actuals Qty], DATEADD('DIM_Datum Umsatz'[Datum],-1, YEAR)) 
			
			VAR MyAverage = (sum4Years + sum3Years + sum2Years + sum1Years) / 4
			
			RETURN 
			    MyAverage
			```
		displayFolder: Forecast
		lineageTag: 4c462c52-8131-4f41-8659-fa9a6058ed3a

		formatStringDefinition = bpi.Formating.Qty()

	measure 'Current Value Qty' = ```
			
			VAR lastSales = MAX('DIM_Datum Umsatz'[Datum]) 
			RETURN
			    SWITCH(
			            TRUE(),
			            ISBLANK([Actuals Qty]), [Forecast Qty],
			            [Actuals Qty] > [Forecast Qty], [Actuals Qty],
			            MAX('DIM_Datum Umsatz'[Datum]) > lastSales, [Actuals Qty],
			            [Actuals Qty] < [Forecast Qty], ([Forecast Qty] - [Actuals Qty]) + [Actuals Qty],
			            [Forecast Qty]
			            )
			```
		displayFolder: Forecast
		lineageTag: 5d78434f-a4ce-48dc-afc3-d76f54018b04

		formatStringDefinition = bpi.Formating.Qty()

