	/// Umsatz aus Targoverkäufen
	measure 'Umsatz TargoLeasing' = ```
			
			VAR umsatz = CALCULATE( SUM('FACT_Umsatz Produkt'[VKPreisGesamt]), DIM_Kunde[KundenId] IN {5168222, 5140903})
			RETURN 
			IF(ISBLANK(umsatz),0, umsatz)
			    
			```
