	/// Gibt den Monat des größten Wert des Datumsbereiches aus, bezieht sich auf DIM_Datum Umsatz
	measure 'Min Monat' = ```
			
			VAR SDate = [Min Datum]
			    RETURN
			        CALCULATE(SELECTEDVALUE('DIM_Datum Umsatz'[Monat_Nr]), 
			                        FILTER('DIM_Datum Umsatz', 'DIM_Datum Umsatz'[Datum] = SDate)
			                    )
			```
