/// Enthält alle KPI / Measures des DS, diese sind Komplexe Berechnungen die sich nicht mit den einfachen Datenfelder auswerten lassen.
/// 
table KPIs
	lineageTag: e656182f-6618-4ab2-a673-04c1cda07ea0

	/// Gibt das Datum des ersten Umsatzes eines Kunden zurück.
	measure 'Kunde Erster Umsatz' = ```
			
			    CALCULATE( MIN('FACT_Umsatz Belege'[DateCreated]), 
			    FILTER('FACT_Umsatz Belege', 'FACT_Umsatz Belege'[BelegArtId] = 300)
			    )
			```
		formatString: dd.mm.yyyy
		lineageTag: c2bfc75a-2ef3-4a0e-8e9d-8a1b98584160

		annotation PBI_FormatHint = {"isDateTimeCustom":true}

	/// Gibt die Anzahl der Rechnungen des Kunden zurück.
	measure 'Kunde Anzahl Rechnung' = ```
			
			    CALCULATE( COUNT('FACT_Umsatz Belege'[BelegId]), 
			        FILTER('FACT_Umsatz Belege', 'FACT_Umsatz Belege'[BelegArtId] = 300)
			    )
			```
		formatString: #,0
		lineageTag: dd2d035b-1da0-4126-ae4f-92ec5a9f0b79

	/// Gibt die Anzahl der Gutschriften zurück.
	measure 'Anzahl Gutschriften' = ```
			
			    CALCULATE( COUNT('FACT_Umsatz Belege'[BelegId]), 
			        FILTER('FACT_Umsatz Belege', 'FACT_Umsatz Belege'[BelegArtId] = 500)
			    )
			```
		formatString: #,0
		lineageTag: 6f8a572f-27ea-4921-b085-ab81f132d195

	/// Gibt die Anzahl der Rechnungen zurück.
	measure 'Anzahl Rechnungen' = ```
			
			    CALCULATE( COUNT('FACT_Umsatz Belege'[BelegId]), 
			    FILTER('FACT_Umsatz Belege', 'FACT_Umsatz Belege'[BelegArtId] = 300) 
			    )
			```
		formatString: #,0
		lineageTag: 5bfdaa06-bfaf-4efd-8d0b-da9b640d2631

	/// Gibt an ob der Kunden zur Zeitpunkt des Rechnungsdatums Neukunde war.
	measure 'Ist Neukunde' = ```
			
			    IF(SELECTEDVALUE(DIM_Kunde[ErsterVerkauf]) >= MIN('DIM_Datum Umsatz'[Datum]) && SELECTEDVALUE(DIM_Kunde[ErsterVerkauf]) <= MAX('DIM_Datum Umsatz'[Datum]), "Ja", "Nein" )
			```
		lineageTag: 766482be-0dde-4999-8a56-f8bef81fbe7a

	/// Gibt zurück ob der Kunde ein Bestandskunde oder Neukunden ist.
	measure 'C2 Kundenart' = ```
			
			    SELECTEDVALUE('FACT_Umsatz Belege'[Finanzierungskundenart])
			   
			```
		displayFolder: C2 Finanzierung
		lineageTag: 5ff2a1cf-afb2-4484-b3ab-773cc8b43118

	/// Gibt die Anzahl der Neukunden aus der C2 Finanzierung zurück.
	measure 'Anzahl C2 Neukunden' = ```
			
			    CALCULATE( DISTINCTCOUNT('DIM_Leasing Kunden'[KundenId]) ,
			        FILTER('FACT_Umsatz Belege', [Finanzierungskundenart] = "Neukunde"))
			```
		formatString: 0
		displayFolder: C2 Finanzierung
		lineageTag: 6cf6d4ff-ca5c-474d-958a-ddc15d193e4e

	/// Gibt die Bestandskunden aus der C2 Finanzierung zurück.
	measure 'Anzahl C2 Bestandskunden' = ```
			
			    CALCULATE( DISTINCTCOUNT('DIM_Leasing Kunden'[KundenId]), 
			    FILTER('FACT_Umsatz Belege', [Finanzierungskundenart] = "Bestandskunde"))
			```
		formatString: 0
		displayFolder: C2 Finanzierung
		lineageTag: e0672e83-3488-4662-a434-dfbcfe8606ec

	/// Gibt Prozentual die Anzahl der Neukunden aus der C2 Finanzierung zurück.
	measure '% C2 Neukunden' = ```
			
			    DIVIDE( [Anzahl C2 Neukunden],[Anzahl C2 Bestandskunden] + [Anzahl C2 Neukunden], 0)
			```
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: C2 Finanzierung
		lineageTag: 131f8ca2-68b2-44b4-87bd-d7c59ce59eee

	/// Gibt in Abhängigkeit des Mandanten den Link zum Logo zurück.
	measure 'Ausgewähltes Logo JPG' = ```
			
			VAR BaseURL = "https://conference.comspot.de/BC-Logos/_JPG/" 
			VAR EndingURL = ".jpg"
			VAR DefaultURL = "Logo-BYTECLUB-878x1015"
			VAR FullPath =  BaseURL & DefaultURL & EndingURL
			VAR LogoName = IF(HASONEFILTER(DIM_Mandaten[FirmenName]), SELECTEDVALUE(DIM_Mandaten[LogoInJpg]), FullPath) 
			RETURN 
			    LogoName
			```
		displayFolder: Mandanten
		lineageTag: da4b4bf1-4191-47f6-8212-8796c7936cc1
		dataCategory: ImageUrl

	/// Gibt in Abhängigkeit des Mandanten den Link zum Logo zurück.
	measure 'Ausgewähltes Logo PNG' = ```
			
			VAR BaseURL = "https://conference.comspot.de/BC-Logos/_PNG/" 
			VAR EndingURL = ".png"
			VAR DefaultURL = "Logo-BYTECLUB-878x1015"
			VAR FullPath =   BaseURL & DefaultURL & EndingURL
			VAR LogoName = IF(HASONEFILTER(DIM_Mandaten[FirmenName]), SELECTEDVALUE(DIM_Mandaten[LogoInPng]), FullPath) 
			RETURN 
			   LogoName
			```
		displayFolder: Mandanten
		lineageTag: 5a643a47-4d8d-4a7f-a68a-51b3063a7853
		dataCategory: ImageUrl

	/// Basiered auf der Filterung wird eine 0 oder 1 ausgeben. Hier kann eine Abhängigkeit der Slicer erreicht werden. Bitte nur für Slicer verwenden.
	measure 'Slicer Helper' = ```
			
			    INT(NOT ISEMPTY('FACT_Umsatz Belege'))
			```
		formatString: 0
		displayFolder: Helper
		lineageTag: 8fabd4be-c745-4aca-bd62-495695559e25

	/// Gibt die Backlog Menge zurück. Es werden nur Aufträge  die Endgültig sind berücksichtigt
	/// 
	measure 'Backlog Menge' = ```
			
			    CALCULATE( SUM('FACT_Umsatz Produkt'[BacklogMenge]), 
			        FILTER('FACT_Umsatz Belege', 'FACT_Umsatz Belege'[BelegArt] ="Auftrag" && 'FACT_Umsatz Belege'[BelegStatus] = "endgültig")
			    )
			```
		formatString: #,0
		displayFolder: Backlog
		lineageTag: 7ba8c62d-4be9-4c0d-8869-e4e9f36cd268

	/// Kann zum Filtern des Backlogs genutzt werden. Es werden nur Aufträge  die Endgültig sind berücksichtigt
	measure 'Ist Backlog' = IF(SELECTEDVALUE('FACT_Umsatz Belege'[BelegArt]) ="Auftrag" && SELECTEDVALUE('FACT_Umsatz Belege'[BelegStatus]) ="endgültig", true, false)
		formatString: """TRUE"";""TRUE"";""FALSE"""
		displayFolder: Backlog
		lineageTag: 609a94a1-9240-4da4-bee7-43d3d79efe9d

	/// Gibt den Backlog VK zurück. Es werden nur Aufträge  die Endgültig sind berücksichtigt
	measure 'Backlog VK' = ```
			
			    CALCULATE( SUM('FACT_Umsatz Produkt'[BacklogVkPreis]), 
			        FILTER('FACT_Umsatz Belege', 'FACT_Umsatz Belege'[BelegArt] ="Auftrag" && 'FACT_Umsatz Belege'[BelegStatus] = "endgültig")
			    )
			```
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Backlog
		lineageTag: ec64e259-43bd-45b9-bed5-2ac18cf3bfaf

	/// Gibt die Backlog MargeOhneKosten zurück. Es werden nur Aufträge  die Endgültig sind berücksichtigt
	measure 'Backlog MargeOhneKosten' = ```
			
			    CALCULATE( SUM('FACT_Umsatz Produkt'[BacklogMargeOhneKosten]), 
			        FILTER('FACT_Umsatz Belege', 'FACT_Umsatz Belege'[BelegArt] ="Auftrag" && 'FACT_Umsatz Belege'[BelegStatus] = "endgültig")
			    )
			```
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Backlog
		lineageTag: 5000b794-f1be-475c-9007-40b8acbaadeb

	/// Gibt die Backlog Marge Variable Kosten zurück. Es werden nur Aufträge  die Endgültig sind berücksichtigt
	measure 'Backlog MargeVariableKosten' = ```
			
			    CALCULATE( SUM('FACT_Umsatz Produkt'[BacklogMargeVariablekosten]), 
			        FILTER('FACT_Umsatz Belege', 'FACT_Umsatz Belege'[BelegArt] ="Auftrag" && 'FACT_Umsatz Belege'[BelegStatus] = "endgültig")
			    )
			```
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Backlog
		lineageTag: f69afd73-49a3-4d79-a304-09d1dbaec7ca

	/// Gibt die Backlog Gesamt Marge zurück. Es werden nur Aufträge  die Endgültig sind berücksichtigt
	measure 'Backlog MargeGesamtkosten' = ```
			
			    CALCULATE( SUM('FACT_Umsatz Produkt'[BacklogMargeGesamtkosten]), 
			        FILTER('FACT_Umsatz Belege', 'FACT_Umsatz Belege'[BelegArt] ="Auftrag" && 'FACT_Umsatz Belege'[BelegStatus] = "endgültig")
			    )
			```
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Backlog
		lineageTag: 58e96f65-8043-4122-8a73-e3bfb36c3fdd

	/// Gibt den Ausgewählten Vergleichszeitraum zurück. Kann genutzt werden um ein Anzeige zu erstellen.
	measure Label = ```
			
			VAR Selected = SELECTEDVALUE(HLP_Vergleichszeitraum[Id])
			    RETURN
			        SWITCH(Selected , 1, "Vortag", 2, "Vorwoche", 3, "Vormonat", 4, "Vorquartal", 5, "Vorjahr", "Keine Auswahl")
			  
			```
		displayFolder: Vergleichszeitraum
		lineageTag: 91945b7f-cab0-461c-882b-78cf6177784d

	/// Gibt den Umsatz des Vortages zurück.
	measure 'Umsatz Vortag' = ```
			
			VAR SDate = [Max Datum] - 1
			VAR Calc = CALCULATE( SUM('FACT_Umsatz Produkt'[VKPreisGesamt]) ,
			                        FILTER( ALL('DIM_Datum Umsatz'), 'DIM_Datum Umsatz'[Datum] = SDate)
			                    )
			    RETURN
			        IF(Calc = BLANK(), 0, Calc)
			
			```
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Vergleichszeitraum
		lineageTag: 9d289051-c09b-42f1-91b5-bc3a7a8cc624

	/// Gibt den Umsatz des Vorwoche zurück.
	measure 'Umsatz Vorwoche' = ```
			
			VAR WeekId = [Max Kalenderwoche] - 1
			VAR YearId = IF(WeekId = 53, [Max Jahr] - 1, [Max Jahr])
			VAR Calc =  CALCULATE( SUM('FACT_Umsatz Produkt'[VKPreisGesamt]), 
			                    FILTER(ALL('DIM_Datum Umsatz'), 'DIM_Datum Umsatz'[KalenderWoche] = WeekId && 'DIM_Datum Umsatz'[Jahr] = YearId )
			                )
			    RETURN 
			        IF(Calc = BLANK(), 0, Calc)
			```
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Vergleichszeitraum
		lineageTag: ed463d3f-7970-45bd-a0af-af43118648c4

	/// Gibt den Umsatz des Vormonats zurück.
	measure 'Umsatz Vormonat' = ```
			
			VAR _monthid = [Max Monat] - 1
			VAR YearId = IF( _monthid = 12, [Max Jahr] -1 , [Max Jahr])
			VAR Calc =  CALCULATE( SUM('FACT_Umsatz Produkt'[VKPreisGesamt]), 
			    FILTER( ALL('DIM_Datum Umsatz'), 'DIM_Datum Umsatz'[Monat_Nr] = _monthid && 'DIM_Datum Umsatz'[Jahr] = YearId)
			    )
			    RETURN 
			        IF(Calc = BLANK(), 0, Calc)
			   
			```
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Vergleichszeitraum
		lineageTag: 529be8eb-c79f-4d1d-8416-abe84a69776b

	/// Gibt den Umsatz des Vorquartals zurück.
	measure 'Umsatz Vorquartal' = ```
			
			VAR QuartalId = [Max Quartal] -1
			VAR YearId = IF(QuartalId = 4, [Max Jahr] -1, [Max Jahr])
			VAR Calc = CALCULATE( SUM('FACT_Umsatz Produkt'[VKPreisGesamt]), 
			    FILTER( ALL('DIM_Datum Umsatz'), 'DIM_Datum Umsatz'[Quartal] = QuartalId && 'DIM_Datum Umsatz'[Jahr] = YearId)
			    )
			    RETURN 
			        IF(Calc = BLANK(), 0, Calc)
			    
			```
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Vergleichszeitraum
		lineageTag: e67d4fee-a6de-4ade-bd1d-56ec032fa064

	/// Gibt den Umsatz des Vorjahres zurück.
	measure 'Umsatz Vorjahr' = ```
			
			VAR YearId = [Max Jahr] - 1
			VAR Calc = CALCULATE( SUM('FACT_Umsatz Produkt'[VKPreisGesamt]) ,
			        FILTER( ALL('DIM_Datum Umsatz'), 'DIM_Datum Umsatz'[Jahr] = YearId) 
			    )
			    RETURN 
			        IF(Calc = BLANK(), 0, Calc)
			```
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Vergleichszeitraum
		lineageTag: d4b0ba31-ca4e-4928-9709-67a183356ad7

	/// Gibt den Vergleichszeitraum nach Auswahl zurück.
	measure 'Umsatz Switchauswertung' = ```
			
			SWITCH(SELECTEDVALUE(HLP_Vergleichszeitraum[Id]) , 
			                        1, [Umsatz Vortag], 
			                        2, [Umsatz Vorwoche],
			                        3, [Umsatz Vormonat],
			                        4, [Umsatz Vorquartal],
			                        5, [Umsatz Vorjahr],
			                        0)
			
			```
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Vergleichszeitraum
		lineageTag: 230d97ee-eb61-462a-bdc6-89d98240dfca

	/// Gibt die Woche des größten Wert des Datumsbereiches aus, bezieht sich auf DIM_Datum Umsatz
	measure 'Max Kalenderwoche' = ```
			
			VAR SDate = [Max Datum]
			    RETURN
			        CALCULATE(SELECTEDVALUE('DIM_Datum Umsatz'[KalenderWoche]) , 
			                        FILTER('DIM_Datum Umsatz', 'DIM_Datum Umsatz'[Datum] = SDate)
			                        )
			```
		formatString: 0
		displayFolder: Helper
		lineageTag: 2e4b9240-2dee-4b68-bd9a-c4c876004a8a

	/// Gibt das Jahr des größten Wert des Datumsbereiches aus, bezieht sich auf DIM_Datum Umsatz
	measure 'Max Jahr' = ```
			
			VAR SDate = [Max Datum]
			    RETURN
			        CALCULATE(SELECTEDVALUE('DIM_Datum Umsatz'[Jahr]) , 
			                        FILTER('DIM_Datum Umsatz', 'DIM_Datum Umsatz'[Datum] = SDate)
			                        )
			
			```
		formatString: 0
		displayFolder: Helper
		lineageTag: 488cab44-9c30-4716-bb26-b5842583e84e

	/// Gibt den Monat des größten Wert des Datumsbereiches aus, bezieht sich auf DIM_Datum Umsatz
	measure 'Max Monat' = ```
			
			VAR SDate = [Max Datum]
			    RETURN
			        CALCULATE( SELECTEDVALUE('DIM_Datum Umsatz'[Monat_Nr]), 
			                            FILTER( ALL('DIM_Datum Umsatz'), 'DIM_Datum Umsatz'[Datum] = SDate)
			                    )
			```
		formatString: 0
		displayFolder: Helper
		lineageTag: 9a8e46dc-6a50-4e5d-ad77-bb1dd281595e

	/// Gibt das Quartal des größten Wert des Datumsbereiches aus, bezieht sich auf DIM_Datum Umsatz
	measure 'Max Quartal' = ```
			
			VAR SDate = [Max Datum]
			    RETURN
			        CALCULATE( SELECTEDVALUE('DIM_Datum Umsatz'[Quartal]), 
			                            FILTER('DIM_Datum Umsatz', 'DIM_Datum Umsatz'[Datum] = SDate)
			                        )
			```
		formatString: 0
		displayFolder: Helper
		lineageTag: 350dfef0-ed8c-42e6-b267-d4259a01b905

	/// Gibt das Jahr des größten Wert des Datumsbereiches aus, bezieht sich auf DIM_Datum Umsatz
	measure 'Min Jahr' = ```
			
			VAR SDate = [Min Datum]
			    RETURN
			        CALCULATE( SELECTEDVALUE('DIM_Datum Umsatz'[Jahr]), 
			                        FILTER('DIM_Datum Umsatz', 'DIM_Datum Umsatz'[Datum] = SDate)
			            )
			    
			```
		formatString: 0
		displayFolder: Helper
