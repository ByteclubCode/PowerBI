	measure 'Anzahl Rechnungen VJ' = ```
			
			    CALCULATE(COUNT('FACT_Umsatz Belege'[BelegId]), 
			        DATEADD('DIM_Datum Umsatz'[Datum], -1, YEAR) 
			    )
			```
		formatString: 0
		lineageTag: 85740996-ba45-4ba9-9228-6f8287eb078d

	/// Errechnet den durchschnittlichen Umsatz des Vorjahres
	measure 'Ø Umsatz VJ' = ```
			
			    CALCULATE( AVERAGE('FACT_Umsatz Belege'[Umsatz]) ,
			    DATEADD('DIM_Datum Umsatz'[Datum], -1, YEAR) 
			    )
			```
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		lineageTag: f645122d-7a3d-43e9-88aa-d5a7c90761ba

	/// An Hand der Auswahl des Jahr vs. Jahr aus der Hilfstabelle wird ein 0 oder 1 zurückgeliefert das zum Filtern der Ergebnisse genutzt werden kann.
	measure 'Jahr Vs. Jahr Filter' = ```
			
			VAR Jahr1 = SELECTEDVALUE(HLP_JahrZuJahrVergleich[Jahr1]) 
			VAR Jahr2 = SELECTEDVALUE(HLP_JahrZuJahrVergleich[Jahr2]) 
			VAR SelectedJahr = SELECTEDVALUE('DIM_Datum Umsatz'[Jahr])
			RETURN 
			    //Gibt einen Wert von 1 zurück wenn Eine Auswahl getroffen wurde, oder keine Auswahl getroffen wurde
			    IF( (SelectedJahr = Jahr1 || SelectedJahr = Jahr2) || BLANK() = Jahr1 && BLANK() = Jahr2, 
			    1,
			    0)
			```
		formatString: 0
		displayFolder: Filter
		lineageTag: 90bbe607-cb11-4eb7-b8a7-7c0056a26a0c

	/// Gibt den EK des Backlogs zurück. Es werden nur Aufträge  die Endgültig sind berücksichtigt
	measure 'Backlog EK' = ```
			
			    CALCULATE( SUM('FACT_Umsatz Produkt'[BacklogEK]), 
			        FILTER('FACT_Umsatz Belege', 'FACT_Umsatz Belege'[BelegArt] ="Auftrag" && 'FACT_Umsatz Belege'[BelegStatus] = "endgültig")
			    )
			```
		formatString: #,0.###############\ "€";-#,0.###############\ "€";#,0.###############\ "€"
		displayFolder: Backlog
		lineageTag: 140c6400-4a54-412b-9302-38d263f76d7d

		annotation PBI_FormatHint = {"currencyCulture":"de-DE"}

	/// Verhältnis von Schutzbriefen zu Verkauften Produkten in der Kategorie
	measure '% Schutzbrief' = ```
			
			    DIVIDE([Schutzbriefe], [Verkaufte Artikel], 0)
			```
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: Schutzbrief
		lineageTag: 697c4017-9681-46f4-8909-ec2cef56912d

		changedProperty = FormatString

	/// Verkaufte Artikel zu der Kategorie des Schutzbriefes. Ist keine Kategorie ausgewählt wird die Summe ausgeben.
	measure 'Verkaufte Artikel' = ```
			CALCULATE( SUM('FACT_Umsatz Produkt'[Menge]), 
			                    FILTER( DIM_Produkt,DIM_Produkt[IstSchutzbrief] = FALSE())
			                )
			```
		formatString: 0
		displayFolder: Schutzbrief
		lineageTag: a8fa2c16-c624-42ed-9657-d840839a9428

		changedProperty = FormatString

	/// Bezieht sich auf KD_Kunde und gibt die Anzahl der Neukunden nach gewählten Zeitraum zurück
	measure 'Neukunden Nach Umsatz' = ```
			
			var Neukunde =  CALCULATE( DISTINCTCOUNT('DIM_Kunde'[KundenId]), 
			        FILTER(DIM_Kunde, DIM_Kunde[AnzahlRechnungen] = 1)
			        )
			RETURN
			IF(ISBLANK(Neukunde),0, Neukunde) 
			```
		formatString: #,0
		displayFolder: Umsatzkunden
		lineageTag: 245b5814-8d74-41ea-a1ef-bd890a805306

	/// Bezieht sich auf DIM_Kunde und gibt die Anzahl an Umsatzkunden zurück
	measure 'Kunden mit Umsatz Gesamt' = ```
			DISTINCTCOUNT('DIM_Kunde'[KundenId]) 
			```
		formatString: #,0
		displayFolder: Umsatzkunden
		lineageTag: c2c62c5c-ebf4-430c-a2bd-ea5673070107

	/// Neukunden in Prozent
	measure 'Neukunden in %' = ```
			DIVIDE([Neukunden Nach Umsatz], [Kunden mit Umsatz Gesamt], 0) 
			```
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: Umsatzkunden
		lineageTag: c4334940-49cd-41bc-914f-92c122589c68

	/// Berechnet den Durchschnitt der letzten 4 Jahre zum gegeben Intervall
	measure Forecast = ```
			
			/*
			    Für die Berechung nehmen wir die letzten 4 Jahre 
			*/
			VAR sum4Years = CALCULATE([Actuals], DATEADD('DIM_Datum Umsatz'[Datum],-4, YEAR)) 
			VAR sum3Years = CALCULATE([Actuals], DATEADD('DIM_Datum Umsatz'[Datum],-3, YEAR)) 
			VAR sum2Years = CALCULATE([Actuals], DATEADD('DIM_Datum Umsatz'[Datum],-2, YEAR)) 
			VAR sum1Years = CALCULATE([Actuals], DATEADD('DIM_Datum Umsatz'[Datum],-1, YEAR)) 
			
			VAR MyAverage = (sum4Years + sum3Years + sum2Years + sum1Years) / 4
			
			RETURN 
			    MyAverage
			```
		displayFolder: Forecast
		lineageTag: 4ef40178-e949-402d-8d12-ec4da466b4c7

		formatStringDefinition = bpi.Formating.Currency()

	/// Abweichung zwischen Berechneter Forcast und den Actuals
	measure 'Abweichung zum Forecast' = ```
			
			    [Forecast] - [Actuals]  
			```
		displayFolder: Forecast
		lineageTag: 6b657876-a5ab-46a5-9696-87da2608bf33

		formatStringDefinition = bpi.Formating.Currency()

	/// Umsatz des Vorjahres basierend auf den Ausgewählten Jahr.
	measure 'Gesamt Umsatz VJ' = ```
			
			VAR selectedYear = SELECTEDVALUE('DIM_Datum Umsatz'[Jahr]) 
			VAR salesVJ = CALCULATE(SUM('FACT_Umsatz Produkt'[VKPreisGesamt]), 
			                        ALL('DIM_Datum Umsatz') , 'DIM_Datum Umsatz'[Jahr] = selectedYear - 1)
			RETURN
			    salesVJ 
			```
		formatString: "€"\ #,0;-"€"\ #,0;"€"\ #,0
		displayFolder: Vorjahresvergleich
		lineageTag: 0549ecdc-7cd2-4f32-8b7d-ac6708473381

	/// Erfüllungsquote zum Vorjahr
	measure 'Quote Umsatz zum VJ' = ```
			DIVIDE(SUM('FACT_Umsatz Produkt'[VKPreisGesamt]), [Gesamt Umsatz VJ], 0) 
			```
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: Vorjahresvergleich
		lineageTag: b636bc14-3f6c-452e-9bb3-3f5c70c96b19

	/// Umsatz des Vorjahres bis zum gleichen Tag wie im Ausgewählten Jahr
	measure 'Umsatz VJ YTD' = ```
			
			VAR selectedYear = CONVERT(SELECTEDVALUE('DIM_Datum Umsatz'[Jahr]), INTEGER) -1
			VAR dateToday = TODAY()
			VAR endDate = DATE(selectedYear, MONTH(dateToday), DAY(dateToday))
			VAR salesVJ = CALCULATE( SUM('FACT_Umsatz Produkt'[VKPreisGesamt]) , 
			                    FILTER(
			                        ALL('DIM_Datum Umsatz'), 'DIM_Datum Umsatz'[Jahr] = selectedYear && 'DIM_Datum Umsatz'[Datum] <= endDate
			                        )
			                    )
			                        
			                    
			RETURN 
			    IF(selectedYear + 1 <> YEAR(TODAY()), BLANK(), salesVJ)
			```
		formatString: "€"\ #,0;-"€"\ #,0;"€"\ #,0
		displayFolder: Vorjahresvergleich
		lineageTag: e71354c3-f8be-43fd-8ced-061a4f5de06f

	/// Erfüllungsquote zum Vorjahr
	measure 'Quote Umsatz YOY VJ' = ```
			DIVIDE(SUM('FACT_Umsatz Produkt'[VKPreisGesamt]), [Umsatz VJ YTD], 0) 
			```
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: Vorjahresvergleich
		lineageTag: 1abc1006-e753-4744-8a88-2a0c4705d3ca

	/// Marge des Vorjahres
	measure 'Marge VJ' = ```
			
			VAR mindate = MIN('DIM_Datum Umsatz'[Datum]) 
			VAR maxdate = MAX('DIM_Datum Umsatz'[Datum])
			VAR margin = CALCULATE( 
			                SUM('FACT_Umsatz Produkt'[MargeOhneKosten]) ,
			                 
			                FILTER(ALL('DIM_Datum Umsatz'), 'DIM_Datum Umsatz'[Datum] >= DATE(YEAR(mindate)-1, MONTH(mindate), day(mindate)) && 'DIM_Datum Umsatz'[Datum] <= DATE(YEAR(maxdate) -1, MONTH(maxdate), DAY(maxdate)))
			                )
			RETURN
			    margin
			```
		formatString: "€"\ #,0;-"€"\ #,0;"€"\ #,0
		displayFolder: Vorjahresvergleich
		lineageTag: 04c7d70f-1695-4f0f-9428-b116bf5b582a

	/// Menge des Vorjahres
	measure 'Menge VJ' = ```
			
			VAR mindate = MIN('DIM_Datum Umsatz'[Datum]) 
			VAR maxdate = MAX('DIM_Datum Umsatz'[Datum])
			VAR qty = CALCULATE( 
			                SUM('FACT_Umsatz Produkt'[Menge]) ,
			                 
			                FILTER(ALL('DIM_Datum Umsatz'), 'DIM_Datum Umsatz'[Datum] >= DATE(YEAR(mindate)-1, MONTH(mindate), day(mindate)) && 'DIM_Datum Umsatz'[Datum] <= DATE(YEAR(maxdate) -1, MONTH(maxdate), DAY(maxdate)))
			                )
			RETURN
			    qty
			```
		formatString: #,0
		displayFolder: Vorjahresvergleich
		lineageTag: 480decb7-8945-4343-b487-56257545bcb0

	/// Marge in Prozent von VJ
	measure '% Marge VJ' = ```
			DIVIDE([Marge VJ], [Umsatz VJ], 0) 
			```
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: Vorjahresvergleich
		lineageTag: 886fb207-ee47-428e-9c49-2a3e6105d776

	/// Marge des Vorjahres bis zum Heutigen Tag
	measure 'Marge VJ YTD' = ```
			
			VAR selectedYear = CONVERT(SELECTEDVALUE('DIM_Datum Umsatz'[Jahr]), INTEGER) -1
			VAR dateToday = TODAY()
			VAR endDate = DATE(selectedYear, MONTH(dateToday), DAY(dateToday))
			VAR marginVJ = CALCULATE( SUM('FACT_Umsatz Produkt'[MargeOhneKosten]) , 
			                    FILTER(
			                        ALL('DIM_Datum Umsatz'), 'DIM_Datum Umsatz'[Jahr] = selectedYear && 'DIM_Datum Umsatz'[Datum] <= endDate)
			                    )
			                    
			RETURN 
			    IF(selectedYear + 1 <> YEAR(TODAY()), BLANK(), marginVJ)
			```
		formatString: "€"\ #,0;-"€"\ #,0;"€"\ #,0
		displayFolder: Vorjahresvergleich
