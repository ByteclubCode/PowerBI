	/// Umsatz ohne Targo
	measure 'Umsatz ohne TargoLeasing' =
			
			VAR umsatz = CALCULATE(SUM('FACT_Umsatz Produkt'[VKPreisGesamt]), NOT(DIM_Kunde[KundenId] IN {5168222, 5140903}))
			RETURN
			    IF(ISBLANK(umsatz),0,umsatz)
		formatString: "€"\ #,0;-"€"\ #,0;"€"\ #,0
		displayFolder: TargoLeasing
