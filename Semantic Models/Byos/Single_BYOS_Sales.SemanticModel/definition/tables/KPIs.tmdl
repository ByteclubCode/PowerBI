	/// Prozentuales Verhältnis zwischen Umsatz und Targoumsatz
	measure '% Verhältnis Umsatz zu Targo' = ```
			
			    DIVIDE([Umsatz TargoLeasing],SUM('FACT_Umsatz Produkt'[VKPreisStueck]), 1)
			```
