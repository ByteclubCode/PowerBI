	measure 'Current Value' = ```
			
			VAR lastSales = MAX('DIM_Datum Umsatz'[Datum]) 
			RETURN
			    SWITCH(
			            TRUE(),
			            ISBLANK([Actuals]), [Forecast],
			            [Actuals] > [Forecast], [Actuals],
			            MAX('DIM_Datum Umsatz'[Datum]) > lastSales, [Actuals],
			            [Actuals] < [Forecast], ([Forecast] - [Actuals]) + [Actuals],
			            [Forecast]
			            )
			```
		displayFolder: Forecast
		lineageTag: ab71d867-53bc-4c13-90c5-529812f2a21d

		formatStringDefinition = bpi.Formating.Currency()

	measure Actuals = ```
			SUM('FACT_Umsatz Produkt'[VKPreisGesamt]) 
			```
