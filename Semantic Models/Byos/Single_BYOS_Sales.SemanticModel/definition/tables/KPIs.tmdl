	/// Erfüllungsquote zum Vorjahr im Jahresvergleich
	measure 'Quote Marge YOY VJ' = ```
			DIVIDE(SUM('FACT_Umsatz Produkt'[MargeOhneKosten]), [Marge VJ YTD], 0) 
