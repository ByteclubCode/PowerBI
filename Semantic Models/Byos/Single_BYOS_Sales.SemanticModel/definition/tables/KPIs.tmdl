	/// Gibt die Kalenderwoche des größten Wert des Datumsbereiches aus, bezieht sich auf DIM_Datum Umsatz
	measure 'Min Kalenderwoche' = ```
			
			VAR SDate = [Min Datum]
			    RETURN
			        CALCULATE( SELECTEDVALUE('DIM_Datum Umsatz'[KalenderWoche]), 
			                        FILTER('DIM_Datum Umsatz', 'DIM_Datum Umsatz'[Datum] = SDate)
			            )
			    
			```
		formatString: 0
