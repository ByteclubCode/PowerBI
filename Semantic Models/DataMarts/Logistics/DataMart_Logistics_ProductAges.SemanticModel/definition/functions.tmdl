function 'bpi.Formating.Currency' = ```
					() => 
					VAR CurrentValue = 
					    CALCULATE ( SELECTEDMEASURE (), ALLSELECTED () )
					VAR _abs = ABS(IF(ISBLANK(CurrentValue), 0, CurrentValue))
					VAR _format = SWITCH (
					        TRUE (),
					        _abs <= 1E3, "€#,0.00",
		        			_abs <= 1E6, "€#,0,.00 K",
		        			_abs <= 1E9, "€#,0,,.00 M",
		        			_abs <= 1E12, "€#,0,,.00 M"
					    ) 
					RETURN
					_format
		```
	lineageTag: 780f2fc9-7b4f-4800-b60b-457ff5760e89

function 'bpi.Formating.Qty' = ```
		() => 
		VAR CurrentValue = 
		    CALCULATE (SELECTEDMEASURE(), ALLSELECTED ())
		VAR _abs = ABS(INT(CurrentValue))	
		VAR _format = SWITCH (
		        TRUE (),
		        _abs <= 1E3, "#,0 K",
		        _abs <= 1E6, "#,0 K",
		        _abs <= 1E9, "#,0 M",
		        _abs <= 1E12, "#,0 B"
		    ) 
		RETURN
		_format
		```
	lineageTag: 295227d5-ed52-471d-b1be-20c06174693a

/// AddTax takes in amount and returns amount including tax
function 'bpi.Helper.ConvertToNonBlank' =
		(input : val, output: val) =>
		    IF(ISBLANK(input), output, input)
	lineageTag: e736fb23-22c8-4a6a-b331-4e8130a477b7

